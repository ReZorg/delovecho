{
  "compilerOptions": {
    "noEmit": true,
    "sourceMap": true,
    "noImplicitAny": true,
    "module": "ES2022",
    "target": "es2022",
    "rootDirs": [".", "../shared"],
    "allowJs": false,
    "esModuleInterop": true,
    "moduleResolution": "Node10",
    "strictNullChecks": true,
    "strict": true,
    "skipLibCheck": true,
    "types": [],
    "baseUrl": ".",
    "paths": {
      "dove9": ["../../../dove9/src/index.ts"],
      "dove9/*": ["../../../dove9/src/*"]
    }
  },
  "include": ["./**/*.ts", "./**/*.js"]

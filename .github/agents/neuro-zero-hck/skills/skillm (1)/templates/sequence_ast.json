{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Skillm Action Sequence AST",
  "description": "Abstract Syntax Tree for a procedural action sequence generated by a Skillm",
  "type": "object",
  "required": ["version", "goal", "root"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0.0"
    },
    "goal": {
      "type": "string",
      "description": "Natural language description of the goal this sequence achieves"
    },
    "context": {
      "type": "object",
      "description": "Ambient context available to all actions in the sequence",
      "properties": {
        "connectors": {
          "type": "array",
          "items": { "type": "string" },
          "description": "MCP connectors required by this sequence"
        },
        "variables": {
          "type": "object",
          "description": "Named variables that actions can read/write"
        }
      }
    },
    "root": {
      "$ref": "#/$defs/node"
    }
  },
  "$defs": {
    "node": {
      "oneOf": [
        { "$ref": "#/$defs/action" },
        { "$ref": "#/$defs/pipeline" },
        { "$ref": "#/$defs/choice" },
        { "$ref": "#/$defs/loop" },
        { "$ref": "#/$defs/guard" }
      ]
    },
    "action": {
      "type": "object",
      "description": "A single action verb invocation (leaf node)",
      "required": ["type", "verb", "tool"],
      "properties": {
        "type": { "const": "action" },
        "verb": {
          "type": "string",
          "enum": ["DISCOVER", "INSPECT", "CREATE", "MUTATE", "DESTROY", "NAVIGATE", "COMPOSE", "OBSERVE", "ORCHESTRATE", "CLASSIFY"]
        },
        "tool": {
          "type": "string",
          "description": "The MCP tool name to invoke"
        },
        "params": {
          "type": "object",
          "description": "Parameters to pass to the tool"
        },
        "bind": {
          "type": "string",
          "description": "Variable name to bind the result to"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of this action"
        }
      }
    },
    "pipeline": {
      "type": "object",
      "description": "Sequential composition: A ⊗ B ⊗ C (execute in order)",
      "required": ["type", "steps"],
      "properties": {
        "type": { "const": "pipeline" },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/$defs/node" },
          "minItems": 2
        }
      }
    },
    "choice": {
      "type": "object",
      "description": "Additive composition: A ⊕ B ⊕ C (choose one branch)",
      "required": ["type", "branches"],
      "properties": {
        "type": { "const": "choice" },
        "strategy": {
          "type": "string",
          "enum": ["first_success", "highest_confidence", "user_choice", "condition"],
          "default": "first_success"
        },
        "condition": {
          "type": "string",
          "description": "Expression to evaluate for condition-based choice"
        },
        "branches": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["node"],
            "properties": {
              "label": { "type": "string" },
              "when": { "type": "string", "description": "Condition for this branch" },
              "node": { "$ref": "#/$defs/node" }
            }
          },
          "minItems": 2
        }
      }
    },
    "loop": {
      "type": "object",
      "description": "Repeated execution until condition met",
      "required": ["type", "body", "until"],
      "properties": {
        "type": { "const": "loop" },
        "body": { "$ref": "#/$defs/node" },
        "until": {
          "type": "string",
          "description": "Condition expression that terminates the loop"
        },
        "max_iterations": {
          "type": "integer",
          "default": 10
        }
      }
    },
    "guard": {
      "type": "object",
      "description": "Conditional execution with fallback (try/catch pattern)",
      "required": ["type", "try"],
      "properties": {
        "type": { "const": "guard" },
        "try": { "$ref": "#/$defs/node" },
        "catch": { "$ref": "#/$defs/node" },
        "finally": { "$ref": "#/$defs/node" }
      }
    }
  }
}

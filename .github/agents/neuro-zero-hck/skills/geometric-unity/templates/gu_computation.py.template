    """
    Compute the full swervature.
    
    Swervature = Shiab(F_∇) + ★(T_aug)
    
    Args:
        riemann: Riemann curvature tensor
        torsion: Torsion tensor
        metric: Spacetime metric
    
    Returns:
        Tuple of (shiab_term, hodge_torsion_term)
    """
    return compute_swervature(riemann, torsion, metric.components)



def compute_curvature(gamma: np.ndarray, metric: MetricTensor):
    """
    Compute the Riemann curvature tensor.
    
    R^ρ_σμν = ∂_μ Γ^ρ_νσ - ∂_ν Γ^ρ_μσ + Γ^ρ_μλ Γ^λ_νσ - Γ^ρ_νλ Γ^λ_μσ
    
    Args:
        gamma: Christoffel symbols
        metric: Spacetime metric
    
    Returns:
        Riemann tensor of shape (dim, dim, dim, dim)
    """
    curv_comp = CurvatureComputer(metric.components)
    return curv_comp.riemann_from_christoffel(gamma)



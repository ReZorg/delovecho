{
  "name": "deltecho-monorepo",
  "version": "6.0.1",
  "private": true,
  "description": "Deltecho monorepo - Unified Deep Tree Echo cognitive ecosystem",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9.6.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "build:all": "pnpm build:shared && pnpm build:core && pnpm build:dove9 && pnpm build:cognitive && pnpm build:reasoning && pnpm build:orchestrator && pnpm build:ui",
    "lint": "eslint . --ext .ts --max-warnings 0",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --check \"**/*.{ts,json,md}\"",
    "format:fix": "prettier --write \"**/*.{ts,json,md}\"",
    "build:core": "pnpm --filter deep-tree-echo-core build",
    "build:orchestrator": "pnpm --filter deep-tree-echo-orchestrator build",
    "build:dove9": "pnpm --filter dove9 build",
    "build:cognitive": "pnpm --filter @deltecho/cognitive build",
    "build:reasoning": "pnpm --filter @deltecho/reasoning build",
    "build:shared": "pnpm --filter @deltecho/shared build",
    "build:ui": "pnpm --filter @deltecho/ui-components build",
    "check": "pnpm -r check:types",
    "check:core": "pnpm --filter deep-tree-echo-core check:types",
    "check:orchestrator": "pnpm --filter deep-tree-echo-orchestrator check:types",
    "clean": "pnpm -r clean",
    "test": "pnpm -r test",
    "test:core": "pnpm --filter deep-tree-echo-core test",
    "test:e2e": "node ./scripts/run-jest-e2e.mjs",
    "test:membrane": "pnpm --filter @deltecho/membrane-transport test",
    "test:glyph": "pnpm --filter @deltecho/gesture-glyph test",
    "dev:desktop": "pnpm --filter deltecho2 dev",
    "dev:electron": "pnpm --filter deltecho2 dev:electron",
    "start:orchestrator": "pnpm --filter deep-tree-echo-orchestrator start",
    "docs": "typedoc --out docs/api --entryPointStrategy packages deep-tree-echo-core dove9 packages/cognitive packages/shared packages/reasoning || echo 'typedoc not installed; skipping docs generation'",
    "prepare": "husky"
  },
  "pnpm": {
    "overrides": {
      "qs": ">=6.14.1",
      "cross-spawn": ">=7.0.6",
      "micromatch": ">=4.0.8",
      "braces": ">=3.0.3",
      "tar": ">=6.2.1",
      "semver": ">=7.5.4",
      "tough-cookie": ">=4.1.3"
    },
    "supportedArchitectures": {
      "os": [
        "darwin",
        "win32",
        "linux"
      ],
      "cpu": [
        "x64",
        "ia32",
        "arm64"
      ]
    },
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.27",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.4.3",
    "prettier": "^3.7.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typedoc": "^0.27.0",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
